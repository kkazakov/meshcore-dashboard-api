# ─────────────────────────────────────────────────────────────────────────────
# Meshcore Dashboard — All-in-One Development Stack
# Copy this file to docker-aio/.env and adjust values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_DB=meshcore_dashboard
CLICKHOUSE_USER=meshcore
CLICKHOUSE_PASSWORD=meshcore_secret
# Default admin password for the ClickHouse built-in "default" user (can be empty for dev)
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1

# ── API (meshcore-dashboard-api) ──────────────────────────────────────────────

# MeshCore device connection.
# In a pure local dev stack there is no real radio device attached;
# set CONNECTION_TYPE=tcp and point it at a simulator, or leave as tcp
# with a non-existent host — the API will start and log a connection error
# but all HTTP/WS endpoints remain functional.
CONNECTION_TYPE=tcp
TCP_HOST=192.168.88.99
TCP_PORT=5000

BLE_ADDRESS=
BLE_PIN=
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUDRATE=115200

DEBUG=true

# ClickHouse connection used by the API (must match the values above)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=meshcore_dashboard

# Repeater telemetry polling interval (seconds)
REPEATER_POLL_INTERVAL=600

# ── Front-end (meshcore-dashboard-fe) ─────────────────────────────────────────
# These are baked into the nginx image at build time.
API_ENDPOINT=http://localhost:8000
WS_ENDPOINT=ws://localhost:8000
